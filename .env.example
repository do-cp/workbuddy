# ─── WorkBuddy environment variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is already in .gitignore.

# ── Local-first mode (default) ──────────────────────────────────────────────
# By default WorkBuddy answers from the local knowledge base only.
# No API key needed for this mode.

# ── AI mode (optional) ──────────────────────────────────────────────────────
# Set VITE_AI_ENABLED=true to route questions through your backend.
# Your backend reads ANTHROPIC_API_KEY — it must NEVER be set here.
VITE_AI_ENABLED=false

# URL of your backend chat endpoint (e.g. /api/chat or a full URL).
# The endpoint must accept POST { messages: [{role, content}] }
# and return { content: "..." } plus optional { followUps: [...] }.
VITE_API_URL=/api/chat
